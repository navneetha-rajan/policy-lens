# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
.eggs/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Virtual environments
venv/
.venv/
env/
.env/

# Environment variables
.env
.env.*
!.env.example

# ── Node / Frontend (Vite, npm) ───────────────────────────────────────────
# Dependencies (anywhere in the repo)
node_modules/
**/node_modules/

# Lockfile is committed; npm debug logs are not
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output (Vite, Python sdist/wheel, etc.)
**/dist/
**/build/

# Vite caches (project root and dependency pre-bundle under node_modules)
.vite/
**/.vite/

# TypeScript incremental build info (if enabled later)
*.tsbuildinfo

# Test / tooling caches
coverage/
.nyc_output/
.eslintcache

# Vite may write timestamped config sidecars next to vite.config.*
vite.config.*.timestamp-*

# ── Database files ───────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── OS / Editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# ── Misc ────────────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
